#!/usr/bin/env python3
"""
aura - AI-first agent orchestration.

Single command for spawning, messaging, and managing Claude agents.
All output is stable JSON by default.

Usage:
    aura spawn worker --knowledge npta
    aura send worker "do the thing"
    aura check worker
    aura set worker --mode queue
    aura list
"""

import argparse
import sys
import os

# Add parent directory to path for imports
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from commands import spawn, start as start_cmd, quick as quick_cmd, profile as profile_cmd, agent as agent_cmd, skills as skills_cmd, keeper as keeper_cmd, send, queue as queue_cmd, seat as seat_cmd, holding as holding_cmd, agent_map as agent_map_cmd, check, inspect as inspect_cmd, set as set_cmd, list as list_cmd, ledger, resolve, sleep as sleep_cmd, broadcast, capture, stop, sense, watch, posture as posture_cmd, write as write_cmd, route, dash, event, discord_bridge, sessions as sessions_cmd, fleets as fleets_cmd, ether as ether_cmd, clawhip as clawhip_cmd, deferred as deferred_cmd, report as report_cmd, view as view_cmd, placement as placement_cmd
from lib.output import output


def env_float(name, default):
    try:
        return float(os.environ.get(name, default))
    except (TypeError, ValueError):
        return default


def main():
    parser = argparse.ArgumentParser(
        prog="aura",
        description="AI-first agent orchestration",
        epilog=(
            "Agent primitives: spawn, seat, send, queue, report, view, inspect, event. "
            "Operator tools: capture, sense, watch, dash, deferred, sessions, "
            "discord, clawhip, write, ledger."
        ),
    )
    parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)

    subparsers = parser.add_subparsers(dest="command", required=True)

    # spawn
    p_spawn = subparsers.add_parser("spawn", help="Create a new agent")
    p_spawn.add_argument("name", nargs="?", help="Agent name")
    p_spawn.add_argument("--manifest", metavar="PATH",
                         help="Spawn from a tool-readable role manifest such as Desks role.json")
    p_spawn.add_argument("--role-home", metavar="PATH",
                         help="Spawn from a Desks role home directory containing role.json")
    p_spawn.add_argument("--fleet", "-f", metavar="NAME",
                         help="Fleet name (groups agents in one tmux session)")
    p_spawn.add_argument("--fleet-id", metavar="FLEET_ID",
                         help="Stable Aura fleet id; resolves to the fleet's current name")
    p_spawn.add_argument("--knowledge", "-k", metavar="SESSION",
                         help="Nexus session to inherit knowledge from")
    p_spawn.add_argument("--memory", "-m", metavar="SESSION_ID",
                         help="JSONL session to resume")
    p_spawn.add_argument("--resume-session", metavar="SESSION_ID",
                         help="Runtime-native session id to resume for terminal runtimes such as Codex")
    p_spawn.add_argument("--fork-session", metavar="SESSION_ID",
                         help="Runtime-native session id to fork for supported runtimes such as Codex")
    p_spawn.add_argument("--identity-provider", metavar="PROVIDER",
                         help="Explicit external identity provider for this live spawn, e.g. desks")
    p_spawn.add_argument("--identity-id", metavar="ID",
                         help="Explicit external identity id for this live spawn")
    p_spawn.add_argument("--identity-label", metavar="LABEL",
                         help="Human-readable external identity label for this live spawn")
    p_spawn.add_argument("--at", "-a", metavar="REF",
                         help="Slice at: content search, 'L225' (line), '42' (msg#), or UUID")
    p_spawn.add_argument("--slice", "-s", metavar="N",
                         help="[DEPRECATED] Use --at instead. Legacy message number.")
    p_spawn.add_argument("--prompt", "-p", metavar="TEXT",
                         help="Initial prompt (implies --wait)")
    p_spawn.add_argument("--work", metavar="PATH",
                         help="Read initial prompt from WORK.md-style file relative to --cwd")
    p_spawn.add_argument("--cwd", metavar="PATH",
                         help="Working directory/unit folder for the spawned seat (default: current dir)")
    p_spawn.add_argument("--context", metavar="PATH",
                         help="Runtime-native context file to record, e.g. AGENTS.md or CLAUDE.md")
    p_spawn.add_argument("--wait", "-w", action="store_true",
                         help="Wait for mesh registration")
    p_spawn.add_argument("--timeout", type=int, default=30,
                         help="Timeout for --wait (default: 30)")
    p_spawn.add_argument("--model", metavar="MODEL",
                         help="Claude model alias (opus, sonnet) or full name. Passed through to claude.")
    p_spawn.add_argument("--as-pane", dest="as_pane", action="store_true",
                         help="Spawn without stealing focus (tmux -d). Use when spawning from a session a human is watching.")
    p_spawn.add_argument("--silent", dest="silent", action="store_true",
                         help="Silent keeper: skip AGENT_STARTED/AGENT_STOPPED lifecycle hooks. For ledger clones and similar background agents.")
    p_spawn.add_argument("--clone", dest="clone", action="store_true",
                         help="Force an Aura JSONL --memory clone (new UUID, isolated JSONL). Runtime-native conversation forks use --fork-session.")
    p_spawn.add_argument("--runtime", choices=["claude-code", "claude", "hermes", "codex", "omx", "opencode", "openclaw", "shell", "command"],
                         help="Run a generic terminal-backed runtime instead of the Claude wrapper path")
    p_spawn.add_argument("--profile", metavar="NAME",
                         help="Runtime profile name. Hermes defaults to the seat name; for OMX prefer --omx-profile.")
    p_spawn.add_argument("--runtime-profile", metavar="REF",
                         help="Explicit Aura runtime profile ref such as codex/dev")
    p_spawn.add_argument("--boxed", action="store_true",
                         help="Request an Aura-managed boxed runtime home when supported by the selected runtime")
    p_spawn.add_argument("--omx-profile", metavar="NAME",
                         help="Explicit OMX boxed-profile template under ~/.aura/omx-profiles/NAME")
    p_spawn.add_argument("--command", dest="launch_command", metavar="CMD",
                         help="Override runtime launch command for terminal-backed spawn")

    # start
    p_start = subparsers.add_parser(
        "start",
        help="Start a fresh Codex seat in a fleet",
        description="Start a fresh Codex seat in a fleet",
    )
    p_start.add_argument("fleet", help="Fleet name")
    p_start.add_argument("seat", help="Seat name")
    p_start.add_argument("--cwd", metavar="PATH",
                         help="Working directory for the seat (default: current dir)")
    p_start.add_argument("--model", metavar="MODEL",
                         help="Codex model option passed through to the runtime")

    # quick
    p_quick = subparsers.add_parser("quick", help="Launch a quick Aura-managed runtime seat from the current directory")
    p_quick.add_argument("runtime", choices=["codex", "omx", "hermes"], help="Runtime to launch")
    profile_group = p_quick.add_mutually_exclusive_group()
    profile_group.add_argument("--default", action="store_true", help="Use or create the runtime default Aura profile")
    profile_group.add_argument("--new", nargs="?", const="", metavar="NAME", help="Create and use a new runtime profile")
    profile_group.add_argument("--profile", metavar="NAME", help="Use an existing runtime profile")
    p_quick.add_argument("--preset", choices=["minimal", "worker", "operator", "debug"], help="Seed the selected profile with a curated skill preset")
    p_quick.add_argument("--fleet", "-f", metavar="NAME", help="Fleet name (default: quick-YYYY-MM-DD-HHMM)")
    p_quick.add_argument("--seat", metavar="NAME", help="Seat name (default: <runtime>-<shortid>)")
    p_quick.add_argument("--cwd", metavar="PATH", help="Working directory for the seat (default: current dir)")
    p_quick.add_argument("--prompt", "-p", metavar="TEXT", help="Initial prompt")
    p_quick.add_argument("--work", metavar="PATH", help="Read initial prompt from a work file relative to --cwd")
    p_quick.add_argument("--model", metavar="MODEL", help="Model option passed through to the runtime")
    p_quick.add_argument("--wait", "-w", action="store_true", help="Wait for runtime observation/readiness")
    p_quick.add_argument("--timeout", type=int, default=30, help="Timeout for --wait (default: 30)")
    p_quick.add_argument("--as-pane", dest="as_pane", action="store_true", default=bool(os.environ.get("TMUX")), help="Spawn without stealing focus (default when run inside tmux)")
    p_quick.add_argument("--no-as-pane", dest="as_pane", action="store_false", help="Use the normal focused spawn behavior")
    p_quick.add_argument("--attach", action="store_true", help="Attach or switch to the quick launch tmux fleet after spawn")


    # profile — runtime profile inventory and Aura-owned boxed templates
    p_profile = subparsers.add_parser("profile", help="Manage runtime profile inventory and Aura-owned boxed templates")
    profile_sub = p_profile.add_subparsers(dest="profile_action", required=True)
    p_profile_list = profile_sub.add_parser("list", help="List runtime profiles and adapter classifications")
    p_profile_list.add_argument("--runtime", choices=["codex", "omx", "hermes", "opencode", "claude-code", "goose", "aider"], help="Limit to one runtime")
    p_profile_list.add_argument("--include-future", action="store_true", help="Include deferred adapter classifications")
    p_profile_inspect = profile_sub.add_parser("inspect", help="Inspect one profile without reading secret contents")
    p_profile_inspect.add_argument("profile_ref", help="Profile ref such as codex/dev, or bare name with --runtime")
    p_profile_inspect.add_argument("--runtime", choices=["codex", "omx", "hermes", "opencode", "claude-code", "goose", "aider"], help="Runtime for a bare profile name")
    p_profile_create = profile_sub.add_parser("create", help="Create an Aura-owned boxed profile template")
    p_profile_create.add_argument("profile_ref", help="Profile ref such as codex/dev or omx/dev, or bare name with --runtime")
    p_profile_create.add_argument("--runtime", choices=["codex", "omx"], help="Runtime for a bare profile name")
    p_profile_create.add_argument("--from", dest="source_profile", help="Clone from an existing Aura-owned profile ref of the same runtime")
    p_profile_create.add_argument("--preset", choices=["aura-operator"], help="Seed a deterministic skill preset into the profile")
    p_profile_create.add_argument("--description", help="Optional README description for the template")

    # agent package
    p_agent = subparsers.add_parser("agent", help="Create, inspect, or spawn a package-native Aura agent")
    agent_sub = p_agent.add_subparsers(dest="agent_action", required=True)
    p_agent_create = agent_sub.add_parser("create", help="Create a durable package-native agent")
    p_agent_create.add_argument("address", help="Logical address, e.g. flexgraph:chatbot:pipeline:conductor")
    p_agent_create.add_argument("--runtime", required=True, choices=["codex", "omx"], help="Runtime for the package")
    p_agent_create.add_argument("--profile", metavar="REF", help="Runtime profile ref, e.g. omx/operator or operator")
    p_agent_create.add_argument("--cwd", metavar="PATH", help="Default working directory")
    p_agent_create.add_argument("--fleet", metavar="NAME", help="Default Aura fleet/tmux session")
    p_agent_create.add_argument("--seat", metavar="NAME", help="Default Aura seat/tmux window")
    p_agent_create.add_argument("--alias", metavar="NAME", help="Short package alias")
    p_agent_inspect = agent_sub.add_parser("inspect", help="Inspect a package-native agent")
    p_agent_inspect.add_argument("ref", help="Agent id, address, or alias")
    agent_sub.add_parser("census", help="Classify package bodies against registry bindings")
    p_agent_history = agent_sub.add_parser("history", help="Project package-native agent history from Aura registry state")
    p_agent_history.add_argument("ref", help="Agent id, address, or alias")
    p_agent_history.add_argument("--write", action="store_true", help="Write the derived projection to <agent-root>/aura.json")
    p_agent_spawn = agent_sub.add_parser("spawn", help="Spawn a package-native agent")
    p_agent_spawn.add_argument("ref", help="Agent id, address, or alias")
    p_agent_spawn.add_argument("--cwd", metavar="PATH", help="Override working directory for this spawn")
    p_agent_spawn.add_argument("--fleet", metavar="NAME", help="Override fleet for this spawn")
    p_agent_spawn.add_argument("--seat", metavar="NAME", help="Override seat for this spawn")
    p_agent_spawn.add_argument("--prompt", "-p", metavar="TEXT", help="Initial prompt")
    p_agent_spawn.add_argument("--resume-session", metavar="SESSION_ID",
                               help="Runtime-native session id to resume; use 'latest' for the latest registry-bound package session")
    p_agent_spawn.add_argument("--fresh", action="store_true",
                               help="Start a fresh package runtime, bypassing the manifest resume default")
    p_agent_spawn.add_argument("--model", metavar="MODEL", help="Model option passed through to runtime")
    p_agent_spawn.add_argument("--wait", "-w", action="store_true", help="Wait for runtime observation/readiness")
    p_agent_spawn.add_argument("--timeout", type=int, default=30, help="Timeout for --wait")
    p_agent_spawn.add_argument("--as-pane", dest="as_pane", action="store_true", default=bool(os.environ.get("TMUX")), help="Spawn without stealing focus")
    p_agent_spawn.add_argument("--no-as-pane", dest="as_pane", action="store_false", help="Use focused spawn behavior")

    # skills
    p_skills = subparsers.add_parser("skills", help="Manage package-local runtime skills")
    skills_sub = p_skills.add_subparsers(dest="skills_action", required=True)
    p_skills_apply = skills_sub.add_parser("apply", help="Materialize skills into an agent package")
    p_skills_apply.add_argument("--agent", required=True, help="Aura agent package id, address, or alias")
    p_skills_apply.add_argument("--skill", action="append", required=True, help="Skill source directory; repeatable")
    p_skills_apply.add_argument("--mode", choices=["symlink", "copy"], default="symlink", help="Materialization mode")
    p_skills_apply.add_argument("--replace", action="store_true", help="Archive and replace an existing destination")
    p_skills_apply.add_argument("--dry-run", action="store_true", help="Plan without mutating package files")
    p_skills_list = skills_sub.add_parser("list", help="List package-local skills")
    p_skills_list.add_argument("--agent", required=True, help="Aura agent package id, address, or alias")
    p_skills_remove = skills_sub.add_parser("remove", help="Remove one Aura-owned skill from an agent package")
    p_skills_remove.add_argument("--agent", required=True, help="Aura agent package id, address, or alias")
    p_skills_remove.add_argument("skill_name", help="Skill name to remove")
    p_skills_remove.add_argument("--dry-run", action="store_true", help="Plan without mutating package files")
    p_skills_doctor = skills_sub.add_parser("doctor", help="Inspect package-local skill drift")
    p_skills_doctor.add_argument("--agent", required=True, help="Aura agent package id, address, or alias")
    p_skills_sync = skills_sub.add_parser("sync", help="Repair package-local Aura-owned skill drift")
    p_skills_sync.add_argument("--agent", required=True, help="Aura agent package id, address, or alias")
    p_skills_sync.add_argument("--dry-run", action="store_true", help="Plan without mutating package files")
    p_skills_sync.add_argument("--prune", action="store_true", help="Remove unowned symlinks reported as missing-lock drift")
    p_skills_inventory = skills_sub.add_parser("inventory", help="Read-only inventory of skill roots and package skills")
    p_skills_inventory.add_argument("--root", action="append", help="Skill root to scan; repeatable. Defaults to known Codex/Claude/Aura roots")
    p_skills_inventory.add_argument("--no-packages", action="store_true", help="Do not scan Aura agent package .codex/skills directories")
    p_skills_duplicates = skills_sub.add_parser("duplicates", help="Read-only duplicate skill-name report")
    p_skills_duplicates.add_argument("--root", action="append", help="Skill root to scan; repeatable")
    p_skills_duplicates.add_argument("--no-packages", action="store_true", help="Do not scan Aura agent package .codex/skills directories")
    p_skills_duplicates.add_argument("--include-identical", action="store_true", help="Include duplicate names whose content hash is identical")
    p_skills_diff = skills_sub.add_parser("diff", help="Read-only diff of all copies of one skill name")
    p_skills_diff.add_argument("name", help="Skill frontmatter name or directory name")
    p_skills_diff.add_argument("--root", action="append", help="Skill root to scan; repeatable")
    p_skills_diff.add_argument("--no-packages", action="store_true", help="Do not scan Aura agent package .codex/skills directories")
    p_skills_adopt = skills_sub.add_parser("adopt", help="Adopt existing package-local skills into skills.lock.json")
    p_skills_adopt.add_argument("--agent", required=True, help="Aura agent package id, address, or alias")
    p_skills_adopt.add_argument("--write", action="store_true", help="Write skills.lock.json; without this, adoption is dry-run")
    p_skills_adopt.add_argument("--replace-lock", action="store_true", help="Replace the lockfile entries with adopted existing skills")

    # keeper
    p_keeper = subparsers.add_parser("keeper", help="Run and inspect background keeper jobs")
    keeper_sub = p_keeper.add_subparsers(dest="keeper_action", required=True)
    p_keeper_run = keeper_sub.add_parser("run", help="Start a keeper job")
    keeper_run_sub = p_keeper_run.add_subparsers(dest="keeper_kind", required=True)
    p_keeper_memory = keeper_run_sub.add_parser("memory", help="Write a target-agent memory from a Flex session slice")
    p_keeper_memory.add_argument("--target", required=True, help="Target fleet:seat, package id, address, or alias")
    p_keeper_memory.add_argument("--boundary", required=True, help="Memory boundary such as 25, 50, 75, precompact, closeout, or manual")
    p_keeper_memory.add_argument("--force", action="store_true", help="Launch even if the deterministic job already has a result")
    p_keeper_status = keeper_sub.add_parser("status", help="Read keeper job status")
    p_keeper_status.add_argument("job_id")
    p_keeper_result = keeper_sub.add_parser("result", help="Read keeper job result")
    p_keeper_result.add_argument("job_id")
    p_keeper_tail = keeper_sub.add_parser("tail", help="Read the end of a keeper job log")
    p_keeper_tail.add_argument("job_id")
    p_keeper_tail.add_argument("--lines", type=int, default=80, help="Number of log lines to return")

    # agent-map
    p_agent_map = subparsers.add_parser("agent-map", help="Render status-derived map for one managed seat")
    p_agent_map.add_argument("target", help="Seat ref, usually FLEET:SEAT")

    # send
    p_send = subparsers.add_parser("send", help="Send message to agent")
    p_send.add_argument("target", help="Target agent name")
    p_send.add_argument("message", nargs="?", default="", help="Message content")
    p_send.add_argument("--as", dest="sender",
                        help="Send as (default: current Aura seat; required if Aura cannot infer one)")
    p_send.add_argument("--as-service", dest="service_sender",
                        help="Send as an explicit service actor, e.g. chatbot-pipeline")
    p_send.add_argument("--mode", choices=["immediate", "queue", "notify", "auto"],
                        help=argparse.SUPPRESS)
    p_send.add_argument("--nudge", action="store_true",
                        help="Send Enter keystroke to unstick delivery")
    p_send.add_argument("--transport", choices=["auto", "tmux", "mesh"], default="auto",
                        help="Delivery transport: auto uses tmux window if present, otherwise mesh")
    p_send.add_argument("--dedupe-key", metavar="KEY",
                        help="Skip send if this key was already attempted for the target")
    p_send.add_argument("--force", action="store_true",
                        help="Send even if dedupe-key was already attempted")
    p_send.add_argument("--allow-hidden", action="store_true",
                        help="Allow sending to hidden/internal seats such as Ether panels")
    p_send.add_argument("--defer-if-busy", action="store_true",
                        help=argparse.SUPPRESS)
    p_send.add_argument("--defer-ttl", default="15m",
                        help=argparse.SUPPRESS)
    p_send.add_argument("--defer-retry-every", default="15s",
                        help=argparse.SUPPRESS)
    p_send.add_argument("--no-deferred-daemon", action="store_true",
                        help=argparse.SUPPRESS)

    # queue
    p_queue = subparsers.add_parser("queue", help="Hold a message until a report boundary")
    p_queue.add_argument("target", nargs="?", help="Target agent name")
    p_queue.add_argument("message", nargs="?", help="Message content")
    p_queue.add_argument("--as", dest="sender",
                         help="Sender label (default: current Aura seat; required if Aura cannot infer one)")
    p_queue.add_argument("--as-service", dest="service_sender",
                         help="Queue as an explicit service actor, e.g. chatbot-pipeline")
    p_queue.add_argument("--after", default="next-report",
                         help="Release condition: next-report or a report id (default: next-report)")
    p_queue.add_argument("--list", action="store_true",
                         help="List queued messages")
    p_queue.add_argument("--status", choices=["pending", "scheduled", "released", "release_failed"],
                         help="Filter --list by status")
    p_queue.add_argument("--release-report", help=argparse.SUPPRESS)
    p_queue.add_argument("--delay", default="0", help=argparse.SUPPRESS)

    # seat
    p_seat = subparsers.add_parser("seat", help="Manage logical seat identity")
    seat_sub = p_seat.add_subparsers(dest="seat_action", required=True)
    p_seat_rehome = seat_sub.add_parser("rehome", help="Rename/rehome a seat")
    p_seat_rehome.add_argument("source", help="Existing seat ref, usually fleet:seat")
    p_seat_rehome.add_argument("--name", help="New logical seat name")
    p_seat_rehome.add_argument("--fleet", help="New logical fleet")
    p_seat_rehome.add_argument("--role-home", help="Desks role home containing role.json")
    p_seat_rehome.add_argument("--manifest", help="Desks role manifest path")
    p_seat_rehome.add_argument("--move-terminal", action="store_true",
                               help=argparse.SUPPRESS)
    p_seat_rehome.add_argument("--index",
                               help=argparse.SUPPRESS)
    p_seat_rehome.add_argument("--no-alias-old", action="store_true", help="Do not keep old handle as alias")
    p_seat_resolve = seat_sub.add_parser("resolve", help="Resolve a seat, following aliases")
    p_seat_resolve.add_argument("target")
    p_seat_restart = seat_sub.add_parser("restart", help="Replace a seat runtime while preserving logical identity")
    p_seat_restart.add_argument("target", help="Seat ref, usually fleet:seat")
    p_seat_restart.add_argument("--role-home", help="Desks role home containing role.json")
    p_seat_restart.add_argument("--manifest", help="Desks role manifest path")
    p_seat_restart.add_argument("--cwd", help="Override relaunch working directory")
    p_seat_restart.add_argument("--runtime", choices=["claude-code", "claude", "hermes", "codex", "omx", "opencode", "openclaw", "shell", "command"],
                                help="Override runtime for relaunch")
    p_seat_restart.add_argument("--prompt", help="Optional restart bootstrap prompt")
    p_seat_restart.add_argument("--force", action="store_true",
                                help="Restart even without a safe latest report boundary")
    p_seat_restart.add_argument("--dry-run", action="store_true",
                                help="Show restart plan without stopping or relaunching")
    p_seat_rollover = seat_sub.add_parser(
        "rollover",
        help="Start a fresh runtime session for a seat while preserving rollover evidence",
    )
    p_seat_rollover.add_argument("target", help="Seat ref, usually fleet:seat")
    p_seat_rollover.add_argument("--cwd", help="Override relaunch working directory")
    p_seat_rollover.add_argument(
        "--runtime",
        choices=["claude-code", "claude", "hermes", "codex", "omx", "opencode", "openclaw", "shell", "command"],
        help="Override runtime for relaunch",
    )
    p_seat_rollover.add_argument("--prompt", help="Optional first prompt for the fresh runtime session")
    p_seat_rollover.add_argument(
        "--reason",
        default="session rollover",
        help="Reason recorded in the rollover receipt",
    )
    p_seat_rollover.add_argument("--force", action="store_true",
                                 help="Rollover even without a safe latest report boundary")
    p_seat_rollover.add_argument("--dry-run", action="store_true",
                                 help="Show rollover plan without stopping or relaunching")
    p_seat_cut = seat_sub.add_parser("cut", help="End one seat intentionally")
    p_seat_cut.add_argument("name", help="Seat ref, usually fleet:seat")
    p_seat_cut.add_argument("--force", action="store_true",
                            help="Skip graceful shutdown")
    p_seat_sweep = seat_sub.add_parser("sweep", help="Find or remove stale registered seats")
    p_seat_sweep.add_argument("--fleet", "-f", metavar="NAME", help="Limit sweep to one fleet")
    p_seat_sweep.add_argument("--include-hidden", action="store_true",
                              help="Include hidden/internal seats")
    p_seat_sweep.add_argument("--confirm", action="store_true",
                              help="Remove stale registry records; default is dry-run")
    p_seat_audit = seat_sub.add_parser(
        "audit",
