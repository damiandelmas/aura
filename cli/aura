#!/usr/bin/env python3
"""
aura - AI-first agent orchestration.

Single command for spawning, messaging, and managing Claude agents.
All output is stable JSON by default.

Usage:
    aura spawn worker --knowledge npta
    aura send worker "do the thing"
    aura check worker
    aura set worker --mode queue
    aura list
"""

import argparse
import sys
import os

# Add parent directory to path for imports
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from commands import spawn, send, queue as queue_cmd, seat as seat_cmd, check, inspect as inspect_cmd, set as set_cmd, list as list_cmd, ledger, resolve, sleep as sleep_cmd, broadcast, capture, stop, sense, watch, write as write_cmd, route, dash, event, discord_bridge, sessions as sessions_cmd, fleets as fleets_cmd, ether as ether_cmd, clawhip as clawhip_cmd, deferred as deferred_cmd, report as report_cmd, view as view_cmd
from lib.output import output


def env_float(name, default):
    try:
        return float(os.environ.get(name, default))
    except (TypeError, ValueError):
        return default


def main():
    parser = argparse.ArgumentParser(
        prog="aura",
        description="AI-first agent orchestration",
        epilog=(
            "Agent primitives: spawn, seat, send, queue, report, view, inspect, event. "
            "Operator tools: capture, sense, watch, route, dash, deferred, sessions, "
            "ether, discord, clawhip, write, ledger."
        ),
    )
    parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)

    subparsers = parser.add_subparsers(dest="command", required=True)

    # spawn
    p_spawn = subparsers.add_parser("spawn", help="Create a new agent")
    p_spawn.add_argument("name", nargs="?", help="Agent name")
    p_spawn.add_argument("--manifest", metavar="PATH",
                         help="Spawn from a tool-readable role manifest such as Desks role.json")
    p_spawn.add_argument("--role-home", metavar="PATH",
                         help="Spawn from a Desks role home directory containing role.json")
    p_spawn.add_argument("--fleet", "-f", metavar="NAME",
                         help="Fleet name (groups agents in one tmux session)")
    p_spawn.add_argument("--fleet-id", metavar="FLEET_ID",
                         help="Stable Aura fleet id; resolves to the fleet's current name")
    p_spawn.add_argument("--knowledge", "-k", metavar="SESSION",
                         help="Nexus session to inherit knowledge from")
    p_spawn.add_argument("--memory", "-m", metavar="SESSION_ID",
                         help="JSONL session to resume")
    p_spawn.add_argument("--resume-session", metavar="SESSION_ID",
                         help="Runtime-native session id to resume for terminal runtimes such as Codex")
    p_spawn.add_argument("--identity-provider", metavar="PROVIDER",
                         help="Explicit external identity provider for this live spawn, e.g. desks")
    p_spawn.add_argument("--identity-id", metavar="ID",
                         help="Explicit external identity id for this live spawn")
    p_spawn.add_argument("--identity-label", metavar="LABEL",
                         help="Human-readable external identity label for this live spawn")
    p_spawn.add_argument("--at", "-a", metavar="REF",
                         help="Slice at: content search, 'L225' (line), '42' (msg#), or UUID")
    p_spawn.add_argument("--slice", "-s", metavar="N",
                         help="[DEPRECATED] Use --at instead. Legacy message number.")
    p_spawn.add_argument("--prompt", "-p", metavar="TEXT",
                         help="Initial prompt (implies --wait)")
    p_spawn.add_argument("--work", metavar="PATH",
                         help="Read initial prompt from WORK.md-style file relative to --cwd")
    p_spawn.add_argument("--cwd", metavar="PATH",
                         help="Working directory/unit folder for the spawned seat (default: current dir)")
    p_spawn.add_argument("--context", metavar="PATH",
                         help="Runtime-native context file to record, e.g. AGENTS.md or CLAUDE.md")
    p_spawn.add_argument("--wait", "-w", action="store_true",
                         help="Wait for mesh registration")
    p_spawn.add_argument("--timeout", type=int, default=30,
                         help="Timeout for --wait (default: 30)")
    p_spawn.add_argument("--model", metavar="MODEL",
                         help="Claude model alias (opus, sonnet) or full name. Passed through to claude.")
    p_spawn.add_argument("--as-pane", dest="as_pane", action="store_true",
                         help="Spawn without stealing focus (tmux -d). Use when spawning from a session a human is watching.")
    p_spawn.add_argument("--silent", dest="silent", action="store_true",
                         help="Silent keeper: skip AGENT_STARTED/AGENT_STOPPED lifecycle hooks. For ledger clones and similar background agents.")
    p_spawn.add_argument("--clone", dest="clone", action="store_true",
                         help="Force a real fork of --memory session (new UUID, isolated JSONL). Without --clone, --memory resumes in-place (parent and child share JSONL). Equivalent to --at L<tail> unless --at is also set.")
    p_spawn.add_argument("--runtime", choices=["claude-code", "claude", "hermes", "codex", "omx", "opencode", "openclaw", "shell", "command"],
                         help="Run a generic terminal-backed runtime instead of the Claude wrapper path")
    p_spawn.add_argument("--profile", metavar="NAME",
                         help="Runtime profile name (defaults to agent name; used by Hermes)")
    p_spawn.add_argument("--command", dest="launch_command", metavar="CMD",
                         help="Override runtime launch command for terminal-backed spawn")

    # send
    p_send = subparsers.add_parser("send", help="Send message to agent")
    p_send.add_argument("target", help="Target agent name")
    p_send.add_argument("message", nargs="?", default="", help="Message content")
    p_send.add_argument("--as", dest="sender",
                        help="Send as (default: current Aura seat, else cli)")
    p_send.add_argument("--mode", choices=["immediate", "queue", "notify", "auto"],
                        help=argparse.SUPPRESS)
    p_send.add_argument("--nudge", action="store_true",
                        help="Send Enter keystroke to unstick delivery")
    p_send.add_argument("--transport", choices=["auto", "tmux", "mesh"], default="auto",
                        help="Delivery transport: auto uses tmux window if present, otherwise mesh")
    p_send.add_argument("--dedupe-key", metavar="KEY",
                        help="Skip send if this key was already delivered to the target")
    p_send.add_argument("--force", action="store_true",
                        help="Send even if dedupe-key was already delivered")
    p_send.add_argument("--allow-hidden", action="store_true",
                        help="Allow sending to hidden/internal seats such as Ether panels")
    p_send.add_argument("--defer-if-busy", action="store_true",
                        help=argparse.SUPPRESS)
    p_send.add_argument("--defer-ttl", default="15m",
                        help=argparse.SUPPRESS)
    p_send.add_argument("--defer-retry-every", default="15s",
                        help=argparse.SUPPRESS)
    p_send.add_argument("--no-deferred-daemon", action="store_true",
                        help=argparse.SUPPRESS)

    # queue
    p_queue = subparsers.add_parser("queue", help="Hold a message until a report boundary")
    p_queue.add_argument("target", nargs="?", help="Target agent name")
    p_queue.add_argument("message", nargs="?", help="Message content")
    p_queue.add_argument("--as", dest="sender",
                         help="Sender label (default: current Aura seat, else cli)")
    p_queue.add_argument("--after", default="next-report",
                         help="Release condition: next-report or a report id (default: next-report)")
    p_queue.add_argument("--list", action="store_true",
                         help="List queued messages")
    p_queue.add_argument("--status", choices=["pending", "released", "release_failed"],
                         help="Filter --list by status")

    # seat
    p_seat = subparsers.add_parser("seat", help="Manage logical seat identity")
    seat_sub = p_seat.add_subparsers(dest="seat_action", required=True)
    p_seat_rehome = seat_sub.add_parser("rehome", help="Rename/rehome a seat")
    p_seat_rehome.add_argument("source", help="Existing seat ref, usually fleet:seat")
    p_seat_rehome.add_argument("--name", help="New logical seat name")
    p_seat_rehome.add_argument("--fleet", help="New logical fleet")
    p_seat_rehome.add_argument("--role-home", help="Desks role home containing role.json")
    p_seat_rehome.add_argument("--manifest", help="Desks role manifest path")
    p_seat_rehome.add_argument("--move-terminal", action="store_true",
                               help="Move/rename the tmux window to match the new fleet/name")
    p_seat_rehome.add_argument("--index",
                               help="Target tmux window index when used with --move-terminal")
    p_seat_rehome.add_argument("--no-alias-old", action="store_true", help="Do not keep old handle as alias")
    p_seat_resolve = seat_sub.add_parser("resolve", help="Resolve a seat, following aliases")
    p_seat_resolve.add_argument("target")
    p_seat_restart = seat_sub.add_parser("restart", help="Replace a seat runtime while preserving logical identity")
    p_seat_restart.add_argument("target", help="Seat ref, usually fleet:seat")
    p_seat_restart.add_argument("--role-home", help="Desks role home containing role.json")
    p_seat_restart.add_argument("--manifest", help="Desks role manifest path")
    p_seat_restart.add_argument("--cwd", help="Override relaunch working directory")
    p_seat_restart.add_argument("--runtime", choices=["claude-code", "claude", "hermes", "codex", "omx", "opencode", "openclaw", "shell", "command"],
                                help="Override runtime for relaunch")
    p_seat_restart.add_argument("--prompt", help="Optional restart bootstrap prompt")
    p_seat_restart.add_argument("--force", action="store_true",
                                help="Restart even without a safe latest report boundary")
    p_seat_restart.add_argument("--dry-run", action="store_true",
                                help="Show restart plan without stopping or relaunching")
    p_seat_cut = seat_sub.add_parser("cut", help="End one seat intentionally")
    p_seat_cut.add_argument("name", help="Seat ref, usually fleet:seat")
    p_seat_cut.add_argument("--force", action="store_true",
                            help="Skip graceful shutdown")
    p_seat_sweep = seat_sub.add_parser("sweep", help="Find or remove stale registered seats")
    p_seat_sweep.add_argument("--fleet", "-f", metavar="NAME", help="Limit sweep to one fleet")
    p_seat_sweep.add_argument("--include-hidden", action="store_true",
                              help="Include hidden/internal seats")
    p_seat_sweep.add_argument("--confirm", action="store_true",
                              help="Remove stale registry records; default is dry-run")
    p_seat_audit = seat_sub.add_parser(
        "audit",
        help="Read-only audit of current seat projection risks",
    )
    p_seat_audit.add_argument("--fleet", "-f", metavar="NAME", help="Limit audit to one fleet")
    p_seat_audit.add_argument("--include-hidden", action="store_true",
                              help="Include hidden/internal seats")
    p_seat_archive = seat_sub.add_parser(
        "archive",
        help="Move one non-live current seat row to historical ledger and remove it from current registry",
    )
    p_seat_archive.add_argument("target", help="Seat ref, usually fleet:seat")
    p_seat_archive.add_argument("--reason", help="Reason stored in the seat_archived ledger event")
    p_seat_archive.add_argument("--force", action="store_true",
                                help="Archive even if terminal probes still see a live target")
    p_seat_flex = seat_sub.add_parser("inject-flex", help="Idempotently inject Flex project retrieval guidance into a live seat")
    p_seat_flex.add_argument("target", help="Seat ref, usually fleet:seat")
    p_seat_flex.add_argument("--force", action="store_true",
                             help="Send the Flex packet even if the marker is already visible")
    p_seat_flex.add_argument("--dry-run", action="store_true",
                             help="Resolve and inspect, but do not paste into the seat")
    p_seat_flex.add_argument("--capture-lines", type=int, default=5000,
                             help="Terminal scrollback lines to inspect for the existing packet marker")
    seat_sub.add_parser("aliases", help="List seat aliases")
    p_seat_register = seat_sub.add_parser(
        "register-orphan",
        help="Adopt an unregistered live tmux pane into the Aura registry.",
    )
    p_seat_register.add_argument("target", help="FLEET:SEAT")
    p_seat_register.add_argument("--pane", help="Explicit tmux pane ref, e.g. tmux:flex-leaders-2:%48")
    p_seat_register.add_argument("--runtime", help="Runtime name (codex, claude-code, shell, command)")
    p_seat_register.add_argument("--cwd", help="Override the registered cwd; defaults to pane current path")
    p_seat_tag = seat_sub.add_parser(
        "tag",
        help="Write opaque metadata onto a seat.",
    )
    p_seat_tag.add_argument("target", help="FLEET:SEAT")
    p_seat_tag.add_argument("--set", action="append", default=[], metavar="KEY=VALUE",
                            help="Opaque key=value pair; repeatable. Empty value unsets.")
    p_seat_tag.add_argument("--unset", action="append", default=[], metavar="KEY",
                            help="Remove a key entirely; repeatable.")
    p_seat_tag.add_argument("--expect-seat-instance-id", metavar="ID",
                            help="Only tag if the current row has this seat_instance_id.")


    # write
    p_write = subparsers.add_parser("write", help="Write raw text or keys to a terminal seat")
    p_write.add_argument("target", help="Seat name or explicit backend ref like tmux:FLEET:WINDOW")
    p_write.add_argument("message", nargs="?", default="", help="Raw text to write")
    p_write.add_argument("--as", dest="sender",
                         help="Sender label for audit records (default: current Aura seat, else cli)")
    enter_group = p_write.add_mutually_exclusive_group()
    enter_group.add_argument("--enter", dest="enter", action="store_true",
                             help="Submit after writing text")
    enter_group.add_argument("--no-enter", dest="enter", action="store_false",
                             help="Write text without submitting")
    p_write.set_defaults(enter=False)
    p_write.add_argument("--keys", metavar="KEYS",
                         help="Send a key/control sequence instead of message text")
    p_write.add_argument("--capture-before", action="store_true",
                         help="Include terminal capture before the write")
    p_write.add_argument("--capture-after", action="store_true",
                         help="Include terminal capture after the write")
    p_write.add_argument("--ensure-submit", action="store_true",
                         help="After --enter, verify the terminal did not leave a queued message; retry Enter once if needed")
    p_write.add_argument("--allow-hidden", action="store_true",
                         help="Allow writing to hidden/internal seats such as Ether panels")
    p_write.add_argument("--lines", type=int, default=20,
                         help="Capture line count for --capture-before/after (default: 20)")

    # broadcast
    p_broadcast = subparsers.add_parser("broadcast", help="Broadcast message to a fleet")
    p_broadcast.add_argument("parts", nargs="*",
                             help="Either: MESSAGE when --fleet is set, or FLEET MESSAGE")
    p_broadcast.add_argument("--fleet", "-f", metavar="NAME",
                             help="Fleet name")
    p_broadcast.add_argument("--scope", choices=["fleet", "live", "all-live"], default="fleet",
                             help="Broadcast scope: one fleet (default) or all live registered seats")
    p_broadcast.add_argument("--runtime",
                             help="For --scope live, include only seats with this runtime (for example codex)")
    p_broadcast.add_argument("--as", dest="sender",
                             help="Send as (default: current Aura seat, else cli)")
    p_broadcast.add_argument("--transport", choices=["auto", "tmux", "mesh"], default="auto",
                             help="Delivery transport for each target")
    p_broadcast.add_argument("--dedupe-key", metavar="KEY",
                             help="Base dedupe key; target name is appended")
    p_broadcast.add_argument("--force", action="store_true",
                             help="Send even if dedupe-key was already delivered")
    p_broadcast.add_argument("--include-shell", action="store_true",
                             help="Also send to unregistered shell windows like bash")
    p_broadcast.add_argument("--allow-hidden", action="store_true",
                             help="Allow broadcasting to hidden/internal fleets such as Ether panels")

    # check
    p_check = subparsers.add_parser("check", help="Check agent status")
    p_check.add_argument("name", help="Agent name")
    p_check.add_argument("--output", "-o", action="store_true",
                         help="Include terminal output")
    p_check.add_argument("--lines", type=int, default=20,
                         help="Number of output lines (default: 20)")
    p_check.add_argument("--format", choices=["text", "ansi"], default="text",
                         help="Output capture format when --output is used: text or ansi (default: text)")

    # inspect
    p_inspect = subparsers.add_parser("inspect", help="Inspect one seat: status, terminal excerpt, or semantic sense")
    p_inspect.add_argument("name", help="Seat/agent name")
    inspect_mode = p_inspect.add_mutually_exclusive_group()
    inspect_mode.add_argument("--raw", action="store_true",
                              help="Return raw terminal excerpt with mechanical status")
    inspect_mode.add_argument("--sense", action="store_true",
                              help="Run semantic sense over the terminal excerpt")
    p_inspect.add_argument("--lines", type=int, default=40,
                           help="Number of terminal lines to inspect (default: 40)")
    p_inspect.add_argument("--format", choices=["text", "ansi"], default="text",
                           help="Output capture format for status/raw modes: text or ansi (default: text)")
    p_inspect.add_argument("--question", help="Optional question for semantic state inference")
    p_inspect.add_argument("--features", help="Optional comma-separated desired sense features")
    p_inspect.add_argument("--contract",
                           help="Custom sense contract as inline JSON, @file, path, or name under ~/.aura/contracts/sense/")
    p_inspect.add_argument("--sense-mode", choices=["auto", "llm", "heuristic"],
                           default=os.environ.get("AURA_SENSE_MODE", "auto"),
                           help="Sense backend for --sense: local LLM with fallback, LLM-only, or heuristic (default: auto)")
    p_inspect.add_argument("--model", default=os.environ.get("AURA_SENSE_MODEL"),
                           help="Local Ollama model for --sense")
    p_inspect.add_argument("--ollama-host", default=os.environ.get("AURA_OLLAMA_HOST"),
                           help="Ollama host for --sense")
    p_inspect.add_argument("--llm-timeout", type=float,
                           default=env_float("AURA_SENSE_TIMEOUT", 8.0),
                           help="Seconds to wait for local LLM sense before fallback/error")

    # capture
    p_capture = subparsers.add_parser("capture", help="Capture seat terminal output")
    p_capture.add_argument("name", help="Seat/agent name")
    p_capture.add_argument("--lines", type=int, default=20,
                           help="Number of output lines (default: 20)")
    p_capture.add_argument("--format", choices=["text", "ansi"], default="text",
                           help="Capture format: text or ansi (default: text)")

    # sense
    p_sense = subparsers.add_parser("sense", help="Sense inferred semantic state for a seat")
    p_sense.add_argument("name", help="Seat/agent name")
    p_sense.add_argument("--lines", type=int, default=80,
                         help="Number of captured output lines to inspect (default: 80)")
    p_sense.add_argument("--question", help="Optional question for semantic state inference")
    p_sense.add_argument("--features", help="Optional comma-separated desired output features")
    p_sense.add_argument("--contract",
                         help="Custom sense contract as inline JSON, @file, path, or name under ~/.aura/contracts/sense/")
    p_sense.add_argument("--sense-mode", choices=["auto", "llm", "heuristic"],
                         default=os.environ.get("AURA_SENSE_MODE", "auto"),
                         help="Sense backend: local LLM with fallback, LLM-only, or deterministic heuristic (default: auto)")
    p_sense.add_argument("--model", default=os.environ.get("AURA_SENSE_MODEL"),
                         help="Local Ollama model for LLM sense (default: qwen2.5:0.5b)")
    p_sense.add_argument("--ollama-host", default=os.environ.get("AURA_OLLAMA_HOST"),
                         help="Ollama host for LLM sense (default: http://localhost:11434)")
    p_sense.add_argument("--llm-timeout", type=float,
                         default=env_float("AURA_SENSE_TIMEOUT", 8.0),
                         help="Seconds to wait for local LLM sense before fallback/error (default: 8)")

    # watch
    p_watch = subparsers.add_parser("watch", help="Watch a seat through capture/check/sense")
    p_watch.add_argument("name", nargs="?", help="Seat/agent name")
    p_watch.add_argument("--fleet", "-f", metavar="NAME",
                         help="Watch all seats in a fleet; currently requires --once")
    p_watch.add_argument("--lines", type=int, default=80,
                         help="Number of captured output lines to inspect (default: 80)")
    p_watch.add_argument("--interval", type=float, default=5.0,
                         help="Seconds between samples in continuous mode (default: 5)")
    p_watch.add_argument("--once", action="store_true",
                         help="Take one sample and exit")
    p_watch.add_argument("--iterations", type=int,
                         help="Take N bounded samples and exit")
    p_watch.add_argument("--no-sense", action="store_true",
                         help="Only capture/check watch state; do not run sense")
    p_watch.add_argument("--fresh-sense", action="store_true",
                         help="Re-run sense even when terminal output is unchanged")
    p_watch.add_argument("--question", help="Optional question passed through to sense")
    p_watch.add_argument("--features", help="Optional comma-separated desired sense features")
    p_watch.add_argument("--contract",
                         help="Custom sense contract passed through to watch samples")
    p_watch.add_argument("--sense-mode", choices=["auto", "llm", "heuristic"],
                         default=os.environ.get("AURA_SENSE_MODE", "auto"),
                         help="Sense backend passed through to watch samples (default: auto)")
    p_watch.add_argument("--model", default=os.environ.get("AURA_SENSE_MODEL"),
                         help="Local Ollama model for LLM sense")
    p_watch.add_argument("--ollama-host", default=os.environ.get("AURA_OLLAMA_HOST"),
                         help="Ollama host for LLM sense")
    p_watch.add_argument("--llm-timeout", type=float,
                         default=env_float("AURA_SENSE_TIMEOUT", 8.0),
                         help="Seconds to wait for local LLM sense before fallback/error")

    # route
    p_route = subparsers.add_parser("route", help="Evaluate or execute bounded seat-to-seat routing")
    p_route.add_argument("--fleet", "-f", metavar="NAME", required=True,
                         help="Fleet name to observe and route within")
    mode_group = p_route.add_mutually_exclusive_group()
    mode_group.add_argument("--dry-run", action="store_true",
                            help="Evaluate proposed actions without sending (default)")
    mode_group.add_argument("--send", action="store_true",
                            help="Execute eligible send actions")
    p_route.add_argument("--max-actions", type=int,
                         help="Maximum actions to return or send; required >0 with --send; dry-run defaults to 10")
    p_route.add_argument("--policy", metavar="PATH",
                         help="Optional JSON routing policy")
    p_route.add_argument("--lines", type=int, default=80,
                         help="Capture line count for route observation (default: 80)")

    # dash
    p_dash = subparsers.add_parser("dash", help="Manage tmux dashboard layouts for a fleet")
    dash_sub = p_dash.add_subparsers(dest="dash_action", required=True)
    p_dash_tile = dash_sub.add_parser("tile", help="Convert registered seat windows into panes in a dashboard window")
    p_dash_tile.add_argument("--fleet", "-f", metavar="NAME", help="Fleet name")
    p_dash_tile.add_argument("--dashboard", default="dashboard", help="Dashboard window name (default: dashboard)")
    p_dash_tile.add_argument("--layout", default="tiled", choices=["tiled", "even-horizontal", "even-vertical", "main-horizontal", "main-vertical"], help="Tmux layout to apply")
    p_dash_tile.add_argument("--max-panes", type=int, default=20, help="Maximum registered seat windows to tile")

    p_dash_untile = dash_sub.add_parser("untile", help="Break registered dashboard panes back into windows")
    p_dash_untile.add_argument("--fleet", "-f", metavar="NAME", help="Fleet name")
    p_dash_untile.add_argument("--dashboard", default="dashboard", help="Dashboard window name (default: dashboard)")

    p_dash_layout = dash_sub.add_parser("layout", help="Apply a tmux layout to the dashboard window")
    p_dash_layout.add_argument("--fleet", "-f", metavar="NAME", help="Fleet name")
    p_dash_layout.add_argument("--dashboard", default="dashboard", help="Dashboard window name (default: dashboard)")
    p_dash_layout.add_argument("--layout", default="tiled", choices=["tiled", "even-horizontal", "even-vertical", "main-horizontal", "main-vertical"], help="Tmux layout to apply")

    # set
    p_set = subparsers.add_parser("set", help="Set agent properties")
    p_set.add_argument("name", help="Agent name")
    p_set.add_argument("--mode", choices=["immediate", "queue", "notify"],
                       help="Delivery mode")

    # stop
    p_stop = subparsers.add_parser("stop", help="Stop a seat")
    p_stop.add_argument("name", help="Seat/agent name")
    p_stop.add_argument("--force", action="store_true",
                        help="Skip graceful shutdown")

    # list
    p_list = subparsers.add_parser("list", help="List all agents")
    p_list.add_argument("--fleet", "-f", metavar="NAME",
                        help="Filter by fleet")
    p_list.add_argument("--status", choices=["idle", "busy", "waiting"],
