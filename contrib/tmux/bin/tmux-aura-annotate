#!/usr/bin/env bash
set -euo pipefail

# tmux-aura-annotate <meta.json> <note...>
# Append one annotation record to the notes ledger. The meta file (written by
# tmux-aura-resolve-click) carries the resolution evidence: selected text,
# message ref when resolved, runtime session id, fleet:seat, pane, cwd.
# Append-only JSONL — evidence is never rewritten.

meta="${1:-}"
shift || true
note="${*:-}"

if [[ -z "$meta" || -z "$note" ]]; then
  echo "usage: tmux-aura-annotate <meta.json> <note...>" >&2
  exit 1
fi

ledger="${AURA_NOTES_LEDGER:-$HOME/.aura/notes/annotations.jsonl}"
mkdir -p "$(dirname "$ledger")"

META_FILE="$meta" NOTE="$note" LEDGER="$ledger" python3 - <<'PY'
import json
import os
import time

try:
    with open(os.environ["META_FILE"], encoding="utf-8") as handle:
        meta = json.load(handle)
except Exception:
    meta = {}

record = {
    "ts": time.strftime("%Y-%m-%dT%H:%M:%S%z"),
    "note": os.environ.get("NOTE", ""),
    **(meta if isinstance(meta, dict) else {}),
}
with open(os.environ["LEDGER"], "a", encoding="utf-8") as handle:
    handle.write(json.dumps(record, ensure_ascii=False) + "\n")
PY
