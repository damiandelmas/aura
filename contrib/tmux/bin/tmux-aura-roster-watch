#!/usr/bin/env bash
set -euo pipefail

lock="/tmp/tmux-aura-roster-watch.lock"
exec 9>"$lock"
flock -n 9 || exit 0

state="${AURA_STATE_DIR:-$HOME/.aura}/registry/seats.json"
desks="${DESKS_ROOT:-$HOME/.desks}/identities"
refresh="$HOME/.local/bin/tmux-aura-roster-refresh"

[ -x "$refresh" ] || exit 0

fingerprint() {
  {
    [ -f "$state" ] && stat -c '%n %Y %s' "$state" 2>/dev/null || true
    find "$desks" -maxdepth 2 -name identity.json -type f -printf '%p %T@ %s\n' 2>/dev/null | sort
    tmux list-sessions -F '#{session_name}:#{session_windows}' 2>/dev/null | sort
  } | sha1sum | awk '{print $1}'
}

refresh_all() {
  mapfile -t sessions < <(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)
  for session in "${sessions[@]}"; do
    [ -n "$session" ] || continue
    case "$session" in
      aura-*|flex-*|flexgraph-*|desks-*|factory-*) ;;
      *) continue ;;
    esac
    "$refresh" "$session" >/dev/null 2>&1 || true
  done
}

last=""
while :; do
  current="$(fingerprint)"
  if [ "$current" != "$last" ]; then
    refresh_all
    last="$current"
  fi
  sleep 2
done
