{
  "description": "Find all decisions with context, rationale, and alternatives considered",
  "use_case": "Understand why a technical choice was made, what else was considered, and the reasoning",
  "parameters": {
    "topic": {
      "type": "string",
      "required": true,
      "description": "Decision topic or area to search"
    }
  },
  "compose_config": {
    "search": {
      "queries": [
        {"text": "{{topic}}", "filters": {"phase": "design"}, "limit": 3},
        {"text": "{{topic}}", "filters": {"phase": "develop"}, "limit": 3},
        {"text": "{{topic}}", "filters": {"phase": "document"}, "limit": 2}
      ]
    },
    "discovery": {
      "siblings": {
        "section_types": ["Decisions"],
        "has_context": true,
        "has_rationale": true,
        "has_alternatives": true,
        "limit": 20
      }
    }
  }
}
