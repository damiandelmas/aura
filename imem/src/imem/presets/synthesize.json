{
  "description": "Aggregate topic across multiple conversations into unified narrative",
  "use_case": "Synthesize scattered discussions about a concept into coherent understanding",
  "parameters": {
    "topic": {
      "type": "string",
      "required": true,
      "description": "Topic to synthesize across sessions"
    }
  },
  "compose_config": {
    "search": {
      "queries": [
        {"text": "{{topic}}", "filters": {"source": "conversation", "chunk_type": "thinking"}, "limit": 5},
        {"text": "{{topic}}", "filters": {"source": "conversation", "chunk_type": "message"}, "limit": 5},
        {"text": "{{topic}}", "filters": {"source": "conversation", "chunk_type": "patch"}, "limit": 3}
      ]
    },
    "discovery": {
      "genealogy": {
        "order_by": "timestamp",
        "limit": 50
      },
      "temporal": {
        "direction": "both"
      }
    }
  }
}
