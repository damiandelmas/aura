[Unit]
Description=Drive the Aura event-daemon supervisor on a cadence

[Timer]
# First run shortly after boot, then every 30s — a dead daemon is back within
# one cadence. Idempotent: ensure-daemons skips anything already alive.
OnBootSec=30
OnUnitActiveSec=30
AccuracySec=5s
Persistent=true

[Install]
WantedBy=timers.target
